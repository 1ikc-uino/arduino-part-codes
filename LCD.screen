4) Now am gonna show u how add alphabet variable for lcd.screen

first for decaration u have to add

// Variable to store the current letter
char letter = 'a';
// Variable to remember the previous button state
int formerState = HIGH;

for void setup
void setup()
{
    lcd.begin(16, 2);
    pinMode(button, INPUT_PULLUP); // the button entrance
    lcd.setCursor(7, 0); // the positon of the word "letter"
    lcd.print(letter);
}
for void loop
void loop()
{
    int formerState = digitalRead(bouton);

    // Detect a new button press with AND fonction
    if (formerState == LOW && ancienEtat == HIGH)
    {
        // Move to the next letter
        letter++;

        // After z, go back to a
        if (letter > 'z')
        {
            letter = 'a';
        }
        // Type the letter in the screen
        lcd.setCursor(7, 0);
        lcd.print(letter);

        delay(200); // debounce delay
    }
    // Save current state for next loop
    formerState = stateBouton;
}

----------------------------------------------------------------------------------------------------------------------------------------
In this program, we want to display the entire uppercase alphabet on the first line, starting at the 13th character, following the format
shown below. The display will stop after the letter "Z". After pressing the push button, the message "END" will appear in the middle of the screen.
After pressing the push button again, the display will resume from the beginning.

for declaration 
// Current letter
char letter = 'A';

// Previous button state
int formerstate = HIGH;

// Variable to know if display is finished
bool end = false;

for void setup it is the same

for void loop
void loop()
{
    // Read button state
    int stateBouton = digitalRead(button);
    // Detect button press with fonction AND
    if (stateBouton == LOW && ancienEtat == HIGH)
    {
        // If finish is displayed
        if (end == true)
        {
            // Restart from A
            end = false;
            lettre = 'A';
            lcd.clear();
            lcd.setCursor(12, 0);
            lcd.print(letter);
        }
        else
        {
            // type end on lcd.screen
            end = true;
            lcd.clear();
            lcd.setCursor(6, 0);
            lcd.print("END");
        }

        delay(200); // debounce
    }

    // If not finished, continue alphabet scrolling
    if (end == false)
    {
        lcd.setCursor(12, 0);
        lcd.print(lettre);
        delay(500);
        lettre++;
        // Stop after Z
        if (lettre > 'Z')
        {
            lettre = 'Z';
        }
    }
    // Save current button state
    ancienEtat = etatBouton;
}







