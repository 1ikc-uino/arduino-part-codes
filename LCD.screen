Here am gonna explain to u how to LCD I2C screen and u gonna see few exemples it can help u.
----------------------------------------------------------------------------------------------------------------------------------------
1) The library command where u have to start the code with it as declaration command
#include <Wire.h>
#include "rgb_lcd.h"
rgb_lcd lcd;
----------------------------------------------------------------------------------------------------------------------------------------
2) The commands that u have to know for void setup
    lcd.begin(16, 2); // the command lcd.screen is 2x16 
    lcd.setCursor(0, 0); // this command is for position of the word
    lcd.print("Hello Word"); // type "hello Word"
----------------------------------------------------------------------------------------------------------------------------------------
3) here am gonna show u an exemple for how to use the lcd.screen with button
here we got a code of 2 button if we press button 1 it gonna type "Cupcake" on the screen and if we press button 2 it gonna type "Cookie".
For void setup
void setup()
{
    lcd.begin(16, 2);
    pinMode(button1, INPUT_PULLUP);
    pinMode(button2, INPUT_PULLUP);
    lcd.setCursor(0, 0);
    lcd.print("       ");
}
void loop()
{
    // Read button states if it is high or low
    int stateButton1 = digitalRead(Button1);
    int stateButton2 = digitalRead(Button2);
    // Clear line 0
    lcd.setCursor(0, 0);
    lcd.print("                ");

    // If button 2 is pressed type "Cupcake"
    if (stateButton1 == LOW)
    {
        lcd.setCursor(0, 0);
        lcd.print("Cupcake");
    }

    // If button 2 is pressed type "Cookie"
    else if (stateButton2 == LOW)
    {
        lcd.setCursor(0, 0);
        lcd.print("Cookie");
    }
    //if nothing pressed type nothing. U can change it for what ever u want
    else
    {
        lcd.setCursor(0, 0);
        lcd.print("     ");
    }

    delay(100);
}
