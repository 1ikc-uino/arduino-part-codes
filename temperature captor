if temperature > 27 turn on motor. The motor could be a fan

#include <Wire.h>
#include "rgb_lcd.h"

rgb_lcd lcd;

const int sensorPin = A0;   // LM35 sensor pin
const int motorPin = 7;     // Motor control pin

void setup() {

    lcd.begin(16, 2);       // Initialize LCD
    pinMode(motorPin, OUTPUT);

    digitalWrite(motorPin, LOW); // Motor OFF at start
}

void loop() {

    int reading = analogRead(sensorPin); // Read sensor value

    float voltage = reading * (5.0 / 1023.0); // Convert to voltage

    float temperature = voltage * 100.0; // Convert to Celsius

    // Display temperature
    lcd.setCursor(0, 0);
    lcd.print("TEMPERATURE:");

    lcd.setCursor(4, 1);
    lcd.print(temperature, 1);

    lcd.write((unsigned char)223); // Degree symbol °
    lcd.print("C");

    // Motor control
    if (temperature > 27.0) {

        digitalWrite(motorPin, HIGH); // Turn motor ON

        lcd.setCursor(12, 1);
        lcd.print("ON ");

    } else {

        digitalWrite(motorPin, LOW); // Turn motor OFF

        lcd.setCursor(12, 1);
        lcd.print("OFF");
    }

    delay(1000); // Wait 1 second
}

