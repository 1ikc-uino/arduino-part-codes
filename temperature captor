the temperature captor convert the temperature into voltage 10mV=1°C
--------------------------------------------------------------------------------------------------------------------------------------------

#include <Wire.h>
#include "rgb_lcd.h"

rgb_lcd lcd;

const int sensorPin = A0; // LM35 sensor pin

void setup() {
    lcd.begin(16, 2); // Initialize 16x2 LCD
}

void loop() {

    int reading = analogRead(sensorPin); // Read analog value
    float voltage = reading * (5.0 / 1023.0); // Convert to voltage
    float temperature = voltage * 100.0; // LM35: 10mV = 1°C

    lcd.setCursor(0, 0);
    lcd.print("TEMPERATURE:");

    lcd.setCursor(4, 1);
    lcd.print(temperature, 1); // Display 1 decimal

    lcd.write((unsigned char)223); // Degree symbol °
    lcd.print("C");

    delay(1000); // Wait 1 second
}
