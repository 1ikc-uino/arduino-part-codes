#include <Wire.h>
#include "rgb_lcd.h"

rgb_lcd lcd;

const int sensorPin = A0; // GT1107 sensor
const int ledPin = 13;    // Built-in LED

void setup() {

  // LCD initialization
  lcd.begin(16, 2);

  // LED configuration
  pinMode(ledPin, OUTPUT);

  // First message
  lcd.setCursor(0, 0);
  lcd.print("LIGHT SENSOR");
}

void loop() {

  // Read sensor value
  int luxValue = analogRead(sensorPin);

  // Darkness detected
  if (luxValue < 300) {

    lcd.clear();

    lcd.setCursor(0, 0);
    lcd.print("NIGHT");

    lcd.setCursor(0, 1);
    lcd.print("LED ON");

    digitalWrite(ledPin, HIGH);
  }

  // Strong light detected
  else if (luxValue > 700) {

    lcd.clear();

    lcd.setCursor(0, 0);
    lcd.print("DAY");

    lcd.setCursor(0, 1);
    lcd.print("LED OFF");

    digitalWrite(ledPin, LOW);
  }

  // Normal ambient light
  else {

    lcd.clear();

    lcd.setCursor(0, 0);
    lcd.print("NORMAL LIGHT");

    lcd.setCursor(0, 1);
    lcd.print("LED OFF");

    digitalWrite(ledPin, LOW);
  }

  delay(200);
}
