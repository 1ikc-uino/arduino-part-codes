#include <Wire.h>
#include "rgb_lcd.h"
rgb_lcd lcd;
int adcPin = A0;       
int buttonPin = 2;   
int adcIn = 0;
float voltage = 0;
int millivoltage = 0;
void setup()
{
    lcd.begin(16, 2);
    pinMode(buttonPin, INPUT);
    lcd.setCursor(0, 0);
    lcd.print("POTENTIOMETER");
}

void loop()
{
    // Read potentiometer
    adcIn = analogRead(adcPin);
    // Convert values
    voltage = adcIn * 5.0 / 1023.0;
    millivoltage = voltage * 1000;
    // Clear second line
    lcd.setCursor(0, 1);
    lcd.print("                ");
    lcd.setCursor(4, 1);
    // Button control
    if(digitalRead(buttonPin) == HIGH)
    {
        lcd.print(millivoltage);
        lcd.print(" mV");
    }
    else
    {
        lcd.print(voltage);
        lcd.print(" V");
    }

    delay(100);
}
