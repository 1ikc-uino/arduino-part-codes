#include <Wire.h>
#include "rgb_lcd.h"

// LCD declaration
rgb_lcd lcd;
int adcPin = A0;      // Potentiometer connected to A0
int adcIn = 0;        // Variable for analog value
float voltage = 0;    // Variable for voltage
void setup()
{
    // LCD initialization
    lcd.begin(16, 2);
    // Title display
    lcd.setCursor(0, 0);
    lcd.print("POTENTIOMETER");
}

void loop()
{
    // Read analog value
    adcIn = analogRead(adcPin);
    // Convert to voltage (0V to 5V)
    voltage = adcIn * 5.0 / 1023.0;
    // Clear second line
    lcd.setCursor(0, 1);
    lcd.print("                ");
    // Display voltage
    lcd.setCursor(4, 1);
    lcd.print(voltage);
    lcd.print(" V");
    delay(100);
}
