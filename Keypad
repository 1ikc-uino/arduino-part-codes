#include <Keypad.h>
#include <Wire.h>
#include "rgb_lcd.h"

rgb_lcd lcd;

const byte ROWS = 4;
const byte COLS = 3;

// Keypad layout
char keys[ROWS][COLS] = {
  {'1','2','3'},
  {'4','5','6'},
  {'7','8','9'},
  {'*','0','#'}
};

// Arduino pins
byte rowPins[ROWS] = {8, 7, 6, 5};
byte colPins[COLS] = {4, 3, 2};

// Create keypad
Keypad keypad = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS);

// Secret code
String secretCode = "1234";

// Variable to store typed code
String enteredCode = "";

void setup() {

    lcd.begin(16, 2);

    lcd.setCursor(0, 0);
    lcd.print("CODE:");
}

void loop() {

    char key = keypad.getKey();

    // If a key is pressed
    if (key) {

        // Display typed key
        lcd.setCursor(0, 1);
        lcd.print("                ");

        enteredCode += key;

        lcd.setCursor(0, 1);
        lcd.print(enteredCode);

        delay(300);

        // Check when 4 digits are entered
        if (enteredCode.length() == 4) {

            lcd.clear();

            // Correct code
            if (enteredCode == secretCode) {

                lcd.setCursor(1, 1);
                lcd.print("ACCESS VALID");
            }

            // Wrong code
            else {

                lcd.setCursor(1, 1);
                lcd.print("ACCESS REFUSED");
            }

            delay(2000);

            // Reset screen
            lcd.clear();
            lcd.setCursor(0, 0);
            lcd.print("CODE:");

            // Clear entered code
            enteredCode = "";
        }
    }
}
